# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-v1-...

# Per-stage LLM models (all default to google/gemini-3-flash-preview)
CHAT_MODEL=google/gemini-3-flash-preview
INCREMENTAL_MODEL=google/gemini-3-flash-preview
ANALYSIS_MODEL=google/gemini-3-flash-preview
SYNTHESIS_MODEL=google/gemini-3-flash-preview

# Server port (default: 3000)
PORT=3000
